# ============================================
*.key
*.pem
*.crt
*.p12
*.pfx
.env
.env.local
.env.production

# ============================================
# Сторонние зависимости
# ============================================
third_party/external/
third_party/vendor/

# ============================================
# Исходные данные игры
# ============================================
game/*.exe
game/*.dll
game/*.dat
game/*.pak
game/*.bin
game/*.bin
game/*.pak
