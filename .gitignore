# Логи и отладочная информация
# ============================================
*.log
*.dump
*.crash
*.stacktrace

# ============================================
# Операционная система
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
*.dmg

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*.desktop
*.local
.Trash-*

# ============================================
# Node.js (для веб-интерфейса)
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dist/
public/

# ============================================
# Python (для скриптов)
# ============================================
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
*.egg-info/
dist/
build/

# ============================================
