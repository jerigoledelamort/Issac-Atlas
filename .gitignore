# ============================================
# Isaac Atlas — .gitignore
# ============================================

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
*.egg-info/
.pytest_cache/

# IDE
.vscode/
.idea/
*.iml

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Logs
*.log
logs/

# Temp
temp/
*.tmp
*.swp
*~

# Profiling
profiling/

# IDA
*.id0
*.id1
*.id2
*.nam
*.til
*.i64
*.idb

# Ghidra project binaries (keep Decomp/ source)
research/ghidra/*.gpr
research/ghidra/*.lock
research/ghidra/*.lock~
research/ghidra/*.rep/

# Original game files (large binaries, not for git)
research/original/

# Obsidian
.obsidian/

# Secrets
*.key
*.pem
.env
